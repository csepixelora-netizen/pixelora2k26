# Backend local environment example
# Copy this to backend/.env and fill values.

# Comma-separated allowed origins. Use * only for local testing.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Main admin secret — full portal, CSV export, delete all data.
ADMIN_PORTAL_SECRET=replace-with-strong-secret

# Optional: separate codes for committee views. Must exist on whichever host runs
# the API (Render dashboard → Environment). Local .env alone does not apply when
# the frontend calls https://your-service.onrender.com.
ADMIN_SECRET_TECH=
ADMIN_SECRET_NONTECH=
ADMIN_SECRET_FOOD=

# Optional: Firebase Admin service account JSON (single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: Firebase Storage bucket name (example: your-project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=
